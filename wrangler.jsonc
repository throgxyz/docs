{
  // Repo-root wrangler config for Cloudflare Workers static-assets deploy.
  // The deploy step runs `npx wrangler deploy` from the repository root, so the
  // assets directory is referenced relative to the root. `vocs build` emits the
  // static site into vocs/dist/public.
  "name": "docs",
  "compatibility_date": "2026-07-21",
  "assets": {
    "directory": "./vocs/dist/public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
